# Parkbad-GT Environment Variables
# Copy this file to .env.local and fill in the values
# Secrets are managed in Infisical — see project settings for access

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_PROJECT_TITLE=Parkbad-GT
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2023-10-15
SANITY_API_READ_TOKEN=your_sanity_read_token
SANITY_REVALIDATE_SECRET=your_sanity_revalidate_secret

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
REVALIDATION_TOKEN=your_revalidation_token

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_AUDIENCE_ID=your_resend_audience_id

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
